---
import { basics, jobs, skills } from "@/lib/data";

const currentJob = jobs[0];
const yearsOfExperience = new Date().getFullYear() - 2015;
const totalProjects = 6;
const totalSkills = skills.reduce((a, g) => a + g.keywords.length, 0);
---

<section id="about" class="py-20 border-t border-white/5">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-accent font-mono text-sm">/</span>
      <span class="text-xs font-semibold uppercase tracking-widest text-muted">About Me</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <!-- Left: About text -->
      <div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white leading-tight">
          I've been building<br />data systems since 2015
        </h2>
        <p class="mt-6 text-muted leading-relaxed">
          {basics.summary}
        </p>
        <a
          href="#experience"
          class="mt-6 inline-flex items-center gap-2 text-accent font-semibold hover:underline"
        >
          More about me
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right: Stats -->
      <div>
        <div class="grid grid-cols-2 gap-6">
          <div class="rounded-xl bg-surface-card p-6 border border-white/5">
            <span class="text-4xl font-extrabold text-accent">{yearsOfExperience}+</span>
            <p class="mt-1 text-sm text-muted">Years of<br />experience</p>
          </div>
          <div class="rounded-xl bg-surface-card p-6 border border-white/5">
            <span class="text-4xl font-extrabold text-accent">{totalProjects}+</span>
            <p class="mt-1 text-sm text-muted">Major<br />projects</p>
          </div>
          <div class="rounded-xl bg-surface-card p-6 border border-white/5">
            <span class="text-4xl font-extrabold text-accent">{totalSkills}+</span>
            <p class="mt-1 text-sm text-muted">Technical<br />skills</p>
          </div>
          <div class="rounded-xl bg-surface-card p-6 border border-white/5">
            <span class="text-4xl font-extrabold text-accent">4</span>
            <p class="mt-1 text-sm text-muted">Companies<br />worked at</p>
          </div>
        </div>
        <p class="mt-6 text-sm text-muted leading-relaxed">
          Currently at <strong class="text-white">{currentJob.company}</strong> as {currentJob.position}, leading data governance and agentic systems at enterprise scale.
        </p>
      </div>
    </div>
  </div>
</section>
